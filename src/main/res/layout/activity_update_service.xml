<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/health"
    android:padding="20dp"
    android:gravity="center">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Update Service"
        android:textSize="24sp"
        android:textStyle="bold"
        android:layout_marginBottom="20dp"/>

    <EditText
        android:id="@+id/etUpdateServiceId"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Service ID to Update"
        android:inputType="number"/>

    <EditText
        android:id="@+id/etUpdateServiceName"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="New Service Name"
        android:layout_marginTop="10dp"/>

    <EditText
        android:id="@+id/etUpdateServiceDesc"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="New Service Description"
        android:layout_marginTop="10dp"/>

    <Button
        android:id="@+id/btnUpdateService"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Update Service"
        android:layout_marginTop="20dp"/>

</LinearLayout>
